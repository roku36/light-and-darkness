{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Light and Darkness Treasure",
  "version": "0.1.2",
  "identifier": "com.roku.light-and-darkness",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Light and Darkness Treasure",
        "fullscreen": true,
        "decorations": false,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "closable": true,
        "width": 1280,
        "height": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "category": "Game"
  }
}
